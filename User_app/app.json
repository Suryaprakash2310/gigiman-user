{
  "expo": {
    "name": "Gigiman",
    "slug": "gigi-user",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/logogigi.png",
    "notification": {
      "icon": "./assets/images/logogigi.png",
      "color": "#033921"
    },
    "scheme": "gigiman",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.suryaprakash23.gigiuser",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "jsEngine": "hermes",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logogigi.png",
        "monochromeImage": "./assets/images/logogigi.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.suryaprakash23.gigiuser",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBinxX6SohboBjea3jH__3dNXWHK4jQ8xQ"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logogigi.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logogigi.png",
          "imageWidth": 400,
          "resizeMode": "contain",
          "backgroundColor": "#033921",
          "dark": {
            "backgroundColor": "#033921"
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-build-properties"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "046534bc-09e3-4c7d-a2eb-2d541ad533d1"
      }
    },
    "owner": "suryaprakash2310"
  }
}